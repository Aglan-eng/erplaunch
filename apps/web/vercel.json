{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "pnpm --filter @ofoq/shared build && pnpm --filter @ofoq/web build",
  "outputDirectory": "dist",
  "installCommand": "corepack enable && pnpm install --frozen-lockfile",
  "rewrites": [
    { "source": "/((?!assets/|favicon.ico|index.html).*)", "destination": "/index.html" }
  ]
}
