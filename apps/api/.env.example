DATABASE_URL=file:./dev.db
REDIS_URL=redis://localhost:6379
JWT_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-me-in-production
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d
API_PORT=3000
API_HOST=0.0.0.0
CORS_ORIGIN=http://localhost:5173
NODE_ENV=development

# AI Implementation Expert
AI_PROVIDER=anthropic
AI_API_KEY=
AI_MODEL=claude-sonnet-4-20250514

# Twilio — base auth (Phase 5.A portal OTP uses Twilio Verify)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Twilio Verify service SID (create one in console with Email channel; see docs/portal-auth.md)
TWILIO_VERIFY_SERVICE_SID=

# Twilio WhatsApp sender (format: whatsapp:+E164; sandbox or approved production sender)
TWILIO_WHATSAPP_FROM=

# Twilio SMS sender (optional — only if SMS OTP fallback is wired)
TWILIO_SMS_FROM=

# SendGrid (branded transactional mail)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
SENDGRID_FROM_NAME=ERPLaunch

# Portal session auth (Phase 5.A)
PORTAL_SESSION_COOKIE_SECRET=change-me-in-production
PORTAL_SESSION_TTL_DAYS=7
PORTAL_AUTH_RATELIMIT_REQUEST_PER_MIN=3
PORTAL_AUTH_RATELIMIT_VERIFY_PER_MIN=5
