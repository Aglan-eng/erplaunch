# ERPLaunch — environment variable template (Day 4 hardening).
# Copy to .env at each app root and fill in. `required` entries must be set
# in production or the service will refuse to boot. Dev fallbacks are noted
# where they exist.
#
# This file is committed. NEVER put real secrets here.

# ─── Core runtime ──────────────────────────────────────────────────────────
NODE_ENV=development
API_HOST=0.0.0.0
API_PORT=3000
LOG_LEVEL=info
# libSQL/SQLite file URL. Do not use postgresql:// — this project has no
# Postgres driver. See docs/adr for the dialect decision.
DATABASE_URL=file:./dev.db
REDIS_URL=redis://localhost:6379

# ─── Consultant JWT (apps/api) ─────────────────────────────────────────────
# required in prod. dev fallback: "ofoq-dev-secret-local-only"
JWT_SECRET=
# Kept for future refresh-token work; currently only JWT_SECRET is used.
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# ─── Cross-site cookies (apps/api) ─────────────────────────────────────────
# Web origin. In prod must match the deployed SPA URL exactly — CORS will
# reject others. Credentials: true is set on the server; wildcards not
# supported.
CORS_ORIGIN=http://localhost:5173
# Base URL the web SPA is served at. Used inside portal magic-link emails
# so the link opens the right origin.
APP_URL=http://localhost:5173

# ─── Portal session auth (apps/api, Phase 5A) ──────────────────────────────
# required in prod. Separate from JWT_SECRET so a leaked consultant secret
# cannot mint portal sessions.
PORTAL_SESSION_COOKIE_SECRET=
PORTAL_SESSION_TTL_DAYS=7
PORTAL_AUTH_RATELIMIT_REQUEST_PER_MIN=3
PORTAL_AUTH_RATELIMIT_VERIFY_PER_MIN=5

# ─── Portal OTP (apps/api, Phase 5A) ───────────────────────────────────────
PORTAL_OTP_TTL_MINUTES=10
PORTAL_OTP_MAX_ATTEMPTS=5
PORTAL_OTP_CODE_LENGTH=6

# ─── At-rest encryption (apps/api) ─────────────────────────────────────────
# 64 hex chars (32 bytes). Used by services/credentialCipher.ts to encrypt
# firm SMTP passwords + any future stored secrets. Rotating invalidates all
# stored ciphertext. Dev fallback auto-derives a deterministic key and logs
# a warning; prod refuses that path.
ERPLAUNCH_MASTER_KEY=

# ─── AI (apps/api) ─────────────────────────────────────────────────────────
AI_PROVIDER=anthropic
AI_MODEL=claude-sonnet-4-20250514
# required in prod if AI features are enabled for the tenant.
AI_API_KEY=

# ─── Twilio (apps/api) — reserved for future channels work, not used today ─
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=
TWILIO_WHATSAPP_FROM=
TWILIO_SMS_FROM=

# ─── SendGrid (apps/api) — optional alternative transport ──────────────────
# Not currently exercised. Per-firm SMTP via db.FirmEmailSettings is the
# primary outbound path for all portal emails.
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
SENDGRID_FROM_NAME=ERPLaunch

# ─── Web (apps/web) ────────────────────────────────────────────────────────
# Base URL the SPA talks to at runtime. Set at build time (Vite embeds it).
# In Vercel: set as a project env var; Vercel rebuilds on change.
VITE_API_URL=http://localhost:3000

# ─── Landing (apps/landing) ────────────────────────────────────────────────
# Anthropic key for the landing chatbot Edge Function. Vercel-side only.
# Same key naming as apps/api so a single shared secret is possible.
# AI_API_KEY=
